# Telegram — from @BotFather
TELEGRAM_BOT_TOKEN=

# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# Google Sheets
GOOGLE_SHEET_ID=
GOOGLE_WORKSHEET_NAME=Opportunities
GOOGLE_SERVICE_ACCOUNT_FILE=service_account.json

# Owner allowlist — comma-separated Telegram user IDs (get yours from @userinfobot)
ALLOWED_USER_IDS=

# X / Twitter (optional) — copy the auth_token and ct0 cookies from a logged-in x.com session
TWITTER_AUTH_TOKEN=
TWITTER_CT0=
# Override only if the `twitter` binary is not on your PATH
# TWITTER_CLI_BIN=twitter
